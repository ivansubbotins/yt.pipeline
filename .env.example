# YouTube Data API v3 (OAuth2)
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:8080

# Anthropic Claude API
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Recraft API (AI image generation for thumbnails)
# Get your key at https://www.recraft.ai/
# If empty, thumbnails will be generated using Pillow fallback (gradient + text)
RECRAFT_API_KEY=

# ElevenLabs API (voice cloning for dubbing — EN, ES)
# Creator plan ($22/mo, 50 min, API access)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# KrillinAI / KlicStudio (self-hosted dubbing server)
# Default: local on VPS. For remote: http://subbota-inc.ru:8888
KRILLIN_BASE_URL=http://127.0.0.1:8888
